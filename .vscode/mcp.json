{
	"inputs": [
		{
			"type": "promptString",
			"id": "penpot-token",
			"description": "Penpot access token",
			"password": true
		},
		{
			"type": "promptString",
			"id": "figma-api-key",
			"description": "Figma API key",
			"password": true
		}
	],
	"servers": {
		"penpot-remote": {
			"url": "https://test-mcp.penpot.dev/mcp/stream?userToken=${input:penpot-token}",
			"type": "http"
		},
		"figma": {
			"url": "https://mcp.figma.com/mcp",
			"type": "http"
		},
		"penpot-local": {
			"url": "http://localhost:4401/mcp",
			"type": "http"
		},
		"figma-developer-mcp": {
			"servers": {
				"Framelink_Figma_MCP": {
					"type": "stdio",
					"command": "npx",
					"args": [
						"-y",
						"figma-developer-mcp",
						"--figma-api-key=${input:figma-api-key}",
						"--stdio"
					]
				}
			}
		},
		/*
		"figma-developer-mcp-as-aservice": {
			"url": "http://127.0.0.1:3333/mcp",
			"type": "http"
		},
		*/
		"atlassian": {
			"url": "https://mcp.atlassian.com/v1/mcp",
			"type": "http"
		}
	}
}
