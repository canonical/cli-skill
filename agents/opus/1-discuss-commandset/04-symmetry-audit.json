  "critical_breaks_mental_model": [
    {
      "Pair": "add-model / destroy-model",
      "Issue": "destroy is not the inverse of add"
    },
    {
      "Pair": "bootstrap / destroy-controller",
      "Issue": "bootstrap has no semantic relationship to destroy"
    },
    {
      "Pair": "deploy / remove-application",
      "Issue": "deploy is not the inverse of remove"
    }
  ],
  "high_consistent_confusion": [
    {
      "Pair": "integrate / remove-relation",
      "Issue": "integrate replaced add-relation, breaking symmetry"
    },
    {
      "Pair": "set-constraints / constraints",
      "Issue": "Get command is noun-only, set is verb-noun"
    },
    {
      "Pair": "consume / remove-saas",
      "Issue": "consume has no noun; saas is a different concept from offer"
    }
  ],
  "medium_minor_friction": [
    {
      "Pair": "import-ssh-key / remove-ssh-key",
      "Issue": "import vs remove verb mismatch"
    },
    {
      "Pair": "create-backup / download-backup",
      "Issue": "Not inverses"
    },
    {
      "Pair": "attach-resource / —",
      "Issue": "No removal command"
    },
    {
      "Pair": "login / logout",
      "Issue": "Symmetric but whoami is a third command in the same domain"
    }
  ],
  "behavioral_asymmetries": [
    {
      "Forward": "destroy-controller --force",
      "Reverse": "bootstrap",
      "Asymmetry": "Reverse requires cloud setup; forward can be forced"
    },
    {
      "Forward": "remove-application --force",
      "Reverse": "deploy",
      "Asymmetry": "Deploy provisions resources; remove with force skips cleanup"
    },
    {
      "Forward": "remove-unit --destroy-storage",
      "Reverse": "add-unit",
      "Asymmetry": "Add does not auto-create storage; remove can destroy it"
    },
    {
      "Forward": "kill-controller",
      "Reverse": "destroy-controller",
      "Asymmetry": "kill is more forceful but both destroy; two commands for same outcome with different safety"
    }
  ]
}