{
  "command_base_types": [
    {
      "Base Type": "cmd.CommandBase",
      "Use Case": "Simple commands with no API access"
    },
    {
      "Base Type": "modelcmd.ModelCommandBase",
      "Use Case": "Commands that operate within a model context"
    },
    {
      "Base Type": "modelcmd.ControllerCommandBase",
      "Use Case": "Commands that operate at controller scope"
    },
    {
      "Base Type": "modelcmd.OptionalControllerCommand",
      "Use Case": "Commands that may work without a controller"
    }
  ],
  "middleware_and_hooks": [
    {
      "Hook": "Pre-run notification",
      "Mechanism": "SuperCommandParams.NotifyRun"
    },
    {
      "Hook": "Pre-help notification",
      "Mechanism": "SuperCommandParams.NotifyHelp"
    },
    {
      "Hook": "Missing command",
      "Mechanism": "SuperCommandParams.MissingCallback"
    },
    {
      "Hook": "Post-init validation",
      "Mechanism": "Init() method on each command"
    }
  ]
}