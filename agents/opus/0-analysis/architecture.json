{
  "tech_stack": [
    {
      "Component": "Language",
      "Technology": "Go (1.23+)"
    },
    {
      "Component": "CLI Framework",
      "Technology": "Custom cmd package (github.com/juju/juju/cmd/cmd)"
    },
    {
      "Component": "Flag Parsing",
      "Technology": "github.com/juju/gnuflag (GNU getopt-compatible)"
    },
    {
      "Component": "API Transport",
      "Technology": "WebSocket over HTTPS"
    },
    {
      "Component": "API Serialization",
      "Technology": "JSON-RPC"
    },
    {
      "Component": "Client Store",
      "Technology": "YAML files in ~/.local/share/juju/"
    },
    {
      "Component": "Output Formatting",
      "Technology": "Custom cmd.Output with yaml, json, and tabular formatters"
    },
    {
      "Component": "Logging",
      "Technology": "github.com/juju/loggo/v3"
    },
    {
      "Component": "Interactive Shell",
      "Technology": "Custom REPL in cmd/juju/commands/repl.go"
    }
  ],
  "entry_points": [
    {
      "Binary": "juju",
      "Path": "cmd/juju/main.go",
      "Purpose": "Primary CLI client"
    },
    {
      "Binary": "jujud",
      "Path": "cmd/jujud/main.go",
      "Purpose": "Controller/agent daemon"
    },
    {
      "Binary": "juju-containeragent",
      "Path": "cmd/containeragent/mainnix.go",
      "Purpose": "Kubernetes sidecar agent"
    }
  ]
}