  "exit_code_conventions": [
    {
      "Exit Code": "0",
      "Meaning": "Success"
    },
    {
      "Exit Code": "1",
      "Meaning": "General error (command failed, API error, validation error)"
    },
    {
      "Exit Code": "2",
      "Meaning": "CLI usage error (bad args, unrecognized command, missing required arg)"
    }
