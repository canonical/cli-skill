  "step_5_cli-specific_frame_annotations": [
    {
      "Verb": "bootstrap",
      "Proposed Frame Name": "Selfinitializing",
      "Definition": "An Agent causes a distributed system to create itself from minimal inputs.",
      "Core Elements": "Agent, System, Input, Targetenvironment",
      "Closest FrameNet Frame": "Creating [319]",
      "Gap Notes": "Bootstrap implies self-creation without external Creator post-init."
    },
    {
      "Verb": "deploy",
      "Proposed Frame Name": "Provisioning",
      "Definition": "An Agent places software onto infrastructure, configuring and activating it.",
      "Core Elements": "Agent, Software, Infrastructure, Configuration",
      "Closest FrameNet Frame": "Arranging [921]",
      "Gap Notes": "Deploy includes provisioning + configuration + activation, not just arrangement."
    },
    {
      "Verb": "integrate",
      "Proposed Frame Name": "Bidirectionallinking",
      "Definition": "An Agent creates a reciprocal relationship between two systems.",
      "Core Elements": "Agent, System1, System2, Relationshiptype",
      "Closest FrameNet Frame": "Attaching [197]",
      "Gap Notes": "Integration is bidirectional; Attaching is typically unidirectional."
    },
    {
      "Verb": "refresh",
      "Proposed Frame Name": "Repull",
      "Definition": "An Agent re-acquires software from an external source and replaces the local copy.",
      "Core Elements": "Agent, Software, Source, Target",
      "Closest FrameNet Frame": "Rejuvenation [1614]",
      "Gap Notes": "Refresh in Juju means \"pull new charm revision\", not \"restore vigor\"."
    },
    {
      "Verb": "grant",
      "Proposed Frame Name": "Permissiontransfer",
      "Definition": "An Agent transfers access rights to a Recipient for a Resource.",
      "Core Elements": "Agent, Recipient, Resource, Accesslevel",
      "Closest FrameNet Frame": "—",
      "Gap Notes": "No FrameNet frame covers permission granting."
    },
    {
      "Verb": "revoke",
      "Proposed Frame Name": "Permissionretraction",
      "Definition": "An Agent retracts access rights from a Recipient for a Resource.",
      "Core Elements": "Agent, Recipient, Resource, Accesslevel",
      "Closest FrameNet Frame": "—",
      "Gap Notes": "Inverse of Permissiontransfer; not lexicalized in FrameNet."
    },
    {
      "Verb": "update",
      "Proposed Frame Name": "Statemodification",
      "Definition": "An Agent modifies an existing entity's state to a newer version.",
      "Core Elements": "Agent, Entity, Currentstate, Targetstate",
      "Closest FrameNet Frame": "Causechange [683]",
      "Gap Notes": "Update implies version progression; Causechange is more general."
    },
    {
      "Verb": "upgrade",
      "Proposed Frame Name": "Versionadvancement",
      "Definition": "An Agent advances software to a newer major version.",
      "Core Elements": "Agent, Software, Currentversion, Targetversion",
      "Closest FrameNet Frame": "Causechange [683]",
      "Gap Notes": "Upgrade implies version hierarchy; update is more general."
    },
    {
      "Verb": "migrate",
      "Proposed Frame Name": "Relocationtransfer",
      "Definition": "An Agent moves a workload from one environment to another.",
      "Core Elements": "Agent, Workload, Sourceenvironment, Targetenvironment",
      "Closest FrameNet Frame": "Causemotion [55]",
      "Gap Notes": "Migration implies state preservation across environments."
    },
    {
      "Verb": "scale",
      "Proposed Frame Name": "Replicaadjustment",
      "Definition": "An Agent changes the number of replicas for a workload.",
      "Core Elements": "Agent, Workload, Currentcount, Targetcount",
      "Closest FrameNet Frame": "Causechangeofpositiononascale [96]",
      "Gap Notes": "Scale is about discrete count adjustment, not continuous position."
    },
    {
      "Verb": "login",
