#!/usr/bin/bash

mkdir -p /home/workshop/.copilot

# Conditionally write copilot-instructions.md — do not overwrite if user already has one
if [[ ! -f "/home/workshop/.copilot/copilot-instructions.md" ]]; then
    cp "${SDK}/workshop-prompt.md" "/home/workshop/.copilot/copilot-instructions.md"
elif ! grep -Fq "$(head -1 "${SDK}/workshop-prompt.md")" "/home/workshop/.copilot/copilot-instructions.md"; then
    printf '\n' >> "/home/workshop/.copilot/copilot-instructions.md"
    cat "${SDK}/workshop-prompt.md" >> "/home/workshop/.copilot/copilot-instructions.md"
fi
