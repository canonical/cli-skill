# Install MCP server packages (idempotent — npm skips if already present)
npm install --prefer-offline @penpot/mcp figma-developer-mcp

# Start the local Penpot MCP server as a systemd user service
install -D --mode=644 /dev/stdin ~/.config/systemd/user/penpot-mcp.service <<'UNIT'
[Unit]
Description=Penpot MCP Server

[Service]
ExecStart=/bin/bash -lc 'npx @penpot/mcp'
WorkingDirectory=/home/workshop
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
UNIT

systemctl --user daemon-reload
systemctl --user enable --now penpot-mcp

# Configure VS Code MCP servers
mkdir -p /home/workshop/.vscode-server/data/User
cat > /home/workshop/.vscode-server/data/User/mcp.json << 'EOF'
{
	"servers": {
		"penpot-remote": {
			"url": "https://test-mcp.penpot.dev/mcp/stream?userToken=",
			"type": "http"
		},
		"figma": {
			"url": "https://mcp.figma.com/mcp",
			"type": "http"
		},
		"penpot-local": {
			"url": "http://localhost:4401/mcp",
			"type": "http"
		},
		"figma-developer-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"figma-developer-mcp",
				"--figma-api-key=${FIGMA_API_KEY:-YOUR-KEY}",
				"--stdio"
			]
		},
		"atlassian": {
			"url": "https://mcp.atlassian.com/v1/mcp",
			"type": "http"
		}
	},
	"inputs": []
}
EOF
